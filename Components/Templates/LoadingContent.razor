@using AutoCAC.Models

@switch (LoadState)
{
    case LoadingState.Loading:
        <span>Loading...</span>
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                           AriaLabel="Loading" />
        break;
    case LoadingState.NotFound:
        <p>@NotFoundMessage</p>
        break;
    case LoadingState.UnAuthorized:
        <p>@UnAuthorizedMessage</p>
        break;
    case LoadingState.Error:
        <p>Error occured when retrieving data</p>
        break;
    default:
        @ChildContent
        break;
}

@code {
    [Parameter] public LoadingState LoadState { get; set; }
    [Parameter] public RenderFragment ChildContent { get; set; }
    [Parameter] public string NotFoundMessage { get; set; } = "Empty";
    [Parameter] public string UnAuthorizedMessage { get; set; } = "You are not authorized to view this content";
}
