@using Radzen
@inject DialogService DialogService

<RadzenTemplateForm TItem="Txt" Data="@Value" Submit="OnOk">
    @if (!string.IsNullOrWhiteSpace(Header))
    {
        <h3 class="text-lg font-semibold">@Header</h3>
    }
    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p class="text-sm text-gray-600">@Message</p>
    }

    @if (Mask != null)
    {
        <RadzenMask Name="textInput" Mask="@Mask" CharacterPattern="@CharacterPattern"
                    Placeholder="@Placeholder" @bind-Value="Value.String" Style="width:100%" Immediate="true"
                    />
        <RadzenCustomValidator Component="textInput"
                               Text="Please enter a complete value."
                               Validator="@IsMaskComplete"
                               Popup="false" />
    }
    else
    {        
        <RadzenTextBox Name="textInput"
                       @bind-Value="Value.String"
                       Placeholder="@Placeholder"
                       MaxLength="@MaxLength"
                       Style="width:100%" />

        @if (!string.IsNullOrWhiteSpace(DisallowedChars))
        {
            <RadzenRegexValidator Component="textInput"
                                    Text="@($"The characters {DisallowedChars} are not allowed.")"
                                    Pattern="@BuildNoCharsPattern()"
                                    Popup="false" />
        }
    }

    <div class="flex justify-end gap-2">
        <RadzenButton Text="Cancel"
                      ButtonStyle="ButtonStyle.Secondary"
                      Click="OnCancel" IsBusy="_busy" />
        <RadzenButton Text="OK" ButtonType="ButtonType.Submit"
                      ButtonStyle="ButtonStyle.Primary" IsBusy="_busy"/>
    </div>
</RadzenTemplateForm>

@code {
    [Parameter] public string Header { get; set; } = "Enter Text";
    [Parameter] public string Message { get; set; }
    [Parameter] public string Placeholder { get; set; }
    [Parameter] public string InitialValue { get; set; }
    [Parameter] public int? MaxLength { get; set; }
    [Parameter] public string DisallowedChars { get; set; }
    [Parameter] public string Mask { get; set; }
    [Parameter] public string CharacterPattern { get; set; }
    private bool _busy;
    public class Txt
    {
        public string String { get; set; }
    };
    private Txt Value = new();

    protected override void OnInitialized()
    {
        Value.String = InitialValue ?? "";
    }

    private void OnOk()
    {
        _busy = true;
        StateHasChanged();
        DialogService.Close(Value.String);
    }

    private void OnCancel()
    {
        _busy = true;
        StateHasChanged();
        DialogService.Close(null);
    }

    private bool IsMaskComplete()
    {
        if (string.IsNullOrWhiteSpace(Mask))
        {
            return true;
        }

        var value = Value.String ?? "";

        // Length must match the mask length.
        if (value.Length != Mask.Length)
        {
            return false;
        }

        // Every '*' position in the mask must contain a real character.
        // This assumes incomplete positions remain empty/space/placeholder-like.
        for (var i = 0; i < Mask.Length; i++)
        {
            if (Mask[i] == '*')
            {
                if (char.IsWhiteSpace(value[i]))
                {
                    return false;
                }
            }
        }

        return true;
    }

    private bool HasNoDisallowedChars()
    {
        if (string.IsNullOrWhiteSpace(DisallowedChars))
        {
            return true;
        }

        var value = Value.String ?? "";
        return !value.Any(c => DisallowedChars.Contains(c));
    }

    private string BuildNoCharsPattern()
    {
        if (string.IsNullOrWhiteSpace(DisallowedChars)) return "";
        var escaped = System.Text.RegularExpressions.Regex.Escape(DisallowedChars);
        return $"^[^{escaped}]*$";
    }
}