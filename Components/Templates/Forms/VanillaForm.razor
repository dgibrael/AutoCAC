@typeparam TItem where TItem : class, new()
@inject NavigationManager Nav
@inject NotificationService Notifications
@using AutoCAC.Models
@inject IDbContextFactory<mainContext> DbFactory
@using System.Linq.Expressions
<RadzenTemplateForm TItem="TItem" Data="_item"
                    Submit="@OnValidSubmit" Style="@Style" >
    @ChildContent(_item)

    <RadzenRow>
        <RadzenButton Text="Submit" ButtonType="ButtonType.Submit" IsBusy="_isbusy" />
        <RadzenButton Text="Cancel"
                      ButtonStyle="ButtonStyle.Secondary"
                      Click="@OnCancelAsync" IsBusy="_isbusy" />
    </RadzenRow>
</RadzenTemplateForm>

@code {
    [Parameter] public TItem Data { get; set; }
    [Parameter] public RenderFragment<TItem> ChildContent { get; set; }
    [Parameter] public EventCallback CancelClick { get; set; }
    [Parameter] public EventCallback<TItem> AfterSubmit { get; set; }
    [Parameter] public EventCallback<TItem> Submit { get; set; }
    [Parameter] public string Style { get; set; }
    private bool _newItem = true;
    bool _isbusy;
    private TItem _item;

    protected override void OnInitialized()
    {
        _newItem = Data == null;
        _item = Data ?? new TItem();
    }

    private async Task OnCancelAsync()
    {
        if (_isbusy) return;
        _isbusy = true;
        StateHasChanged();
        if (CancelClick.HasDelegate)
        {
            await CancelClick.InvokeAsync();
            return;
        }
        Nav.NavigateToRelative(fromParent: true);
    }

    private async Task OnValidSubmit()
    {
        if (_isbusy) return;
        _isbusy = true;
        StateHasChanged();
        try
        {
            if (Submit.HasDelegate)
            {
                await Submit.InvokeAsync();
                if (AfterSubmit.HasDelegate)
                {
                    await AfterSubmit.InvokeAsync(_item);
                }
                return;
            }
            if (_newItem)
            {
                await DbFactory.AddItemAsync(_item);
            }
            else
            {
                await DbFactory.UpdateItemAsync(_item);
            }
            Notifications.Success("Saved successfully");
            await AfterSubmitInternal();
        }
        finally
        {
            _isbusy = false;
        }
    }
    async Task AfterSubmitInternal()
    {
        if (AfterSubmit.HasDelegate)
        {
            await AfterSubmit.InvokeAsync(_item);
            return;
        }
        string urlSuffix = _newItem ? DbFactory.GetPrimaryKeyValue(_item).ToString() : null;
        Nav.NavigateToRelative(urlSuffix, fromParent: true);
    }
}
