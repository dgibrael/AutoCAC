@typeparam TItem where TItem : class, new()
@using AutoCAC.Models
@inject IDbContextFactory<mainContext> DbFactory
@inject DialogService DialogService
@inject NotificationService Notifications
<RadzenTemplateForm TItem="TItem"
                    Data="_item"
                    Submit="@OnValidSubmit">
    @ChildContent(_item)

    <RadzenRow>
        <RadzenButton Text="Submit" ButtonType="ButtonType.Submit" IsBusy="_isBusy" />
        <RadzenButton Text="Cancel"
                      ButtonStyle="ButtonStyle.Secondary"
                      Click="@(() => DialogService.Close(null))" IsBusy="_isBusy" />
    </RadzenRow>
</RadzenTemplateForm>

@code {
    [Parameter] public TItem Item { get; set; }
    [Parameter] public RenderFragment<TItem> ChildContent { get; set; }
    [Parameter] public bool SaveToDb { get; set; } = true;
    private TItem _item = new();
    bool _isBusy;
    protected override void OnParametersSet()
    {
        _item = Item ?? new TItem();
    }

    private async Task OnValidSubmit()
    {
        if (_isBusy) return;
        _isBusy = true;
        StateHasChanged();
        try
        {            
            if (SaveToDb)
            {
                try
                {
                    await DbFactory.UpdateItemAsync(_item);
                    Notifications.Success("Saved Successfully");
                }
                catch
                {
                    Notifications.Error("Error Occured when attempting to save");
                    _item = null;
                }
            }
        }
        finally
        {
            _isBusy = false;
            DialogService.Close(_item);
        }
    }
}
