@page "/drugrequest"
@using AutoCAC.Models
@inject IDbContextFactory<mainContext> DbFactory
@inject UserContextService User
@inject NotificationService Notifications
@inject DialogService Dialogs
@inject NavigationManager Nav

<DataGridVanilla TItem="DrugRequest" GridModel="GridModel" AddButtonClick="Add">
	<RadzenDataGridColumn TItem="AutoCAC.Models.DrugRequest" Property="Drug.Name" Title="Drug" />
	<RadzenDataGridColumn TItem="AutoCAC.Models.DrugRequest" Property="Ndc" Title="Ndc" />
	<RadzenDataGridColumn TItem="AutoCAC.Models.DrugRequest" Property="PricePerOrder" Title="PricePerOrder" />
	<RadzenDataGridColumn TItem="AutoCAC.Models.DrugRequest" Property="OrderQty" Title="OrderQty" />
	<RadzenDataGridColumn TItem="AutoCAC.Models.DrugRequest" Property="CurrentStatus" Title="CurrentStatus" />
	<RadzenDataGridColumn TItem="AutoCAC.Models.DrugRequest" Property="Comments" Title="Comments" />
	<RadzenDataGridColumn TItem="AutoCAC.Models.DrugRequest" Property="CreatedAt" Title="CreatedAt" />
</DataGridVanilla>


@code {
	DrugReqStatusEnum drugReqStatus = DrugReqStatusEnum.UnSubmitted;
	DataGridHelper<DrugRequest> GridModel = new()
	{
		IncludeColumns = new[] { nameof(DrugRequest.CreatedAt), "Drug.Name", nameof(DrugRequest.Comments) }
	};
	protected override void OnInitialized()
	{
		GridModel.QueryFactory = db =>
		{
			var query = db.DrugRequests
							.Include(x => x.Drug)
							.OrderBy(x => x.CreatedAt)
							.AsQueryable();
			return query;
		};
	}
	private async Task Add()
	{
		var allowed = User.IsInGroupOrSuperuser("SupplyTech", "PharmacistSupervisor", "PharmacyTechSupervisor", "DrugEnterEditView", "DrugEnterEditRequest");
		if (!allowed)
		{
			Notifications.Error("You must be a superuser or belong to one of the following groups to enter a request: SupplyTech, PharmacistSupervisor, PharmacyTechSupervisor, DrugEnterEditView");
			return;
		}
		var ndc = await Dialogs.Ndc();
		if (string.IsNullOrWhiteSpace(ndc))
		{
			return;
		}
		var newRequest = await DrugRequest.Create(DbFactory, ndc, User.UserProfile.Id);
		Nav.NavigateToRelative(newRequest.Id.ToString());
	}
}
