@page "/drugenteredit"
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject ContextMenuService ContextMenuService
@inject TooltipService TooltipService
@inject NotificationService NotificationService
@inject IDbContextFactory<mainContext> DbFactory
@using AutoCAC.Components.Templates
@using AutoCAC.Models
@using AutoCAC.Extensions
@using Microsoft.EntityFrameworkCore
@inject AutoCAC.Services.UserContextService UserContext
@using AutoCAC.Services
@using AutoCAC.Exceptions
@inject RPMSService RPMS
@using System.Text.RegularExpressions

<PageTitle>Drug Enter Edit</PageTitle>
<RadzenTemplateForm TItem="NdcString" Data="@_ndc" Submit="@NdcNdfSearch">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.Left">
        <RadzenLabel Text="Enter full 11 digit ndc to search (xxxxx-xxxx-xx)" />
        <RadzenMask Mask="*****-****-**" Name="NdcField"
                    CharacterPattern="[0-9]"
                    Placeholder="00000-0000-00" @bind-Value="@_ndc.Ndc" Immediate="true"/>
        <RadzenButton Text="Search" ButtonType="ButtonType.Submit" />
    </RadzenStack>
</RadzenTemplateForm>
<hr>
<DrugLookupTbl SelectionChanged="OnDrugSelected" SelectedNdf="selectedNdf" @ref="DrugsTblRef" />
<hr>
<RPMSOutput />

@code {
    private string ndcInput = string.Empty;
    private DrugLookupTbl DrugsTblRef;
    private Ndf selectedNdf;
    private Drug selectedDrug;
    public class NdcString
    {
        public string Ndc { get; set; }
    }
    private NdcString _ndc = new();
    private async Task NdcNdfSearch()
    {
        selectedNdf = null;
        StateHasChanged();
        var isMatch = _ndc.Ndc.Length == 13;
        if (!isMatch)
        {
            NotificationService.Error("NDC must match 11 digit format xxxxx-xxxx-xx");
            return;
        }
        await using var db = await DbFactory.CreateDbContextAsync();
        selectedNdf = await db.Ndfs.Where(x => x.Ndc == _ndc.Ndc).OrderByDescending(x => x.PrintName).FirstOrDefaultAsync();
        if (selectedNdf == null)
        {
            NotificationService.Info("Ndc not found. Unmatched ndcs must be updated manually in RPMS");
            return;
        }
        StateHasChanged();
    }

    private async Task OnDrugSelected(Drug selected)
    {
        selectedDrug = selected;
        if (selectedDrug == null) return;
        await RunRPMSCommands();
        return;
    }
    public sealed record NdcChangeDto
    {
        public string PurchasePrice { get; set; }
        public string PackageSize { get; set; }
    }
    private async Task RunRPMSCommands()
    {
        if (selectedDrug != null)
        {
            RPMS.BlockUserInput = true;
            string msg = "";
            try
            {
                if (selectedDrug.Id == 0)
                {
                    await NewDrug();
                    msg = $"Successfully created {selectedDrug.Name} (ien: {selectedDrug.Id})";
                }
                else
                {
                    msg = await NdcChange();
                }
            }
            catch (Exception ex)
            {
                msg = $"Error: {ex.Message}";
            }
            finally
            {
                await JS.XtermDialogHide();
                RPMS.BlockUserInput = false;
                msg += ". Type another NDC (xxxxx-xxxx-xx) to Enter/Edit another drug, otherwise press cancel.";
                _ndc.Ndc = await DialogService.TextPromptAsync("Enter/Edit Additional?", msg, mask: "*****-****-**", characterPattern: "[0-9]");
                if (!string.IsNullOrWhiteSpace(_ndc.Ndc))
                {
                    await NdcNdfSearch();
                }
            }
        }
    }

    private async Task<string> NdcChange()
    {
        var ndfPackageSize = !string.IsNullOrWhiteSpace(selectedNdf.PackageSize) ? selectedNdf.PackageSize :
                                selectedDrug.PackageSize ?? "";
        ndfPackageSize = ndfPackageSize.Trim();
        NdcChangeDto ndcInitial = new NdcChangeDto()
        {
            PackageSize = ndfPackageSize.EndsWith(".0")
                    ? ndfPackageSize[..^2]
                    : ndfPackageSize
        };
        var ndcResult = await DialogService.OpenAutoFormAsync<NdcChangeDto>(ndcInitial
            , title: $"Enter the Purchase Price and Size of the order (in {selectedDrug.DispenseUnit})");
        if (ndcResult is null || string.IsNullOrWhiteSpace(ndcResult.PurchasePrice))
        {
            return $"Cancelled changes to {selectedDrug.Name} (ien: {selectedDrug.Id})";
        }
        await JS.XtermDialogShow();
        await GoToNdcChangeMenu();
        await RPMS.SendAsync(selectedNdf.Ndc);
        await RPMS.SendAsync(ndcResult.PurchasePrice);
        await RPMS.SendAsync(ndcResult.PackageSize);
        return $"Successfully saved changes to {selectedDrug.Name} (ien: {selectedDrug.Id})";
    }

    private async Task NewDrug()
    {
        await JS.XtermDialogShow();
        await RPMS.GoToMenu("DRUG");
        await RPMS.SendAsync(selectedDrug.Name);
        for (int i = 0; i < 20; i++)
        {
            string prompt = RPMS.CheckPrompt("Yes//", "No//", "CHOOSE");
            switch (prompt)
            {
                case "No//":
                    await CreateNewDrug();
                    return;
                case "Yes//":
                    string lastStr = RPMS.Output.Buffered;
                    if (lastStr.Contains("Lookup: GENERIC NAME"))
                    {
                        var parameters = new Dictionary<string, object>
                        {
                            { "SelectedNdf", selectedNdf },
                            { "drug", selectedDrug },
                            { "nullOnCancel", true}
                        };
                        selectedDrug = await DialogService.OpenAsync<DrugForm>($"The name {selectedDrug.Name} already exists", parameters);
                        if (selectedDrug == null)
                        {
                            await DrugsTblRef.ClearSelection();
                            await InvokeAsync(StateHasChanged);
                            return;
                        }
                        await RPMS.GoToMenu("DRUG");
                        await RPMS.SendAsync(selectedDrug.Name);
                    }
                    else
                    {
                        await RPMS.SendAsync("NO");
                    }
                    break;
                case "CHOOSE":
                    await RPMS.SendAsync("^");
                    break;
                default:
                    throw new RPMSException();
            }
        }
        throw new RPMSException("Max loops reached");
    }

    private async Task CreateNewDrug()
    {
        await RPMS.SendAsync("YES");
        RPMS.CheckPromptAndThrow("DRUG NUMBER:");
        selectedDrug.Id = int.Parse(RPMS.Output.CurrentValue);
        await RPMS.EnterUntil("DRUG MESSAGE");
        await RPMS.SendAsync(selectedDrug.Message);
        await RPMS.EnterUntil("DEA, SPECIAL HDLG:");
        await RPMS.SendAsync(selectedDrug.DeaSpcl);
        RPMS.CheckPromptAndThrow("DAW CODE:");
        await RPMS.SendAsync("^ORDER UNIT", selectedDrug.OrderUnit, selectedDrug.DispenseUnit, selectedDrug.DispenseUnitsPerOrderUnit?.ToString(), selectedDrug.NcpdpDispenseUnit, selectedNdf.Ndc);
        RPMS.CheckPromptAndThrow("PRICE PER ORDER UNIT:");
        await RPMS.SendAsync(selectedDrug.PricePerOrderUnit?.ToString());
        await RPMS.EnterUntil("NATIONAL DRUG file?");
        await RPMS.SendAsync("YES");
        await RPMS.PromptLoopAsync(new Dictionary<string, Func<Task<bool>>>
        {
            ["Yes or No"] = async () => { await RPMS.SendAsync("YES"); return false; },
            ["Is this a match "] = async () => { await RPMS.SendAsync("YES"); return false; },
            ["Press Return"] = async () => { await RPMS.SendAsync(); return false; },
            ["Enter RETURN to continue"] = async () => { await RPMS.SendAsync(); return false; },
            [" edit "] = async () => { return true; },
            ["osages"] = async () => { return true; }
        }, 20);
        await RPMS.EnterUntil("Enter your choice(s) separated by commas");
        await RPMS.SendAsync(selectedDrug.ApplicationPackage);
        await RPMS.PromptLoopAsync(new Dictionary<string, Func<Task<bool>>>
        {
            ["AN Outpatient Pharmacy ITEM"] = OutpatientPackage,
            ["AN Unit Dose ITEM"] = UDPackage,
            ["A Non-VA Med ITEM"] = YesOnly,
            ["AN IV ITEM"] = YesAndUphat,
            ["Orderable Item"] = async () => { return true; }
        }, 10);
    }

    private async Task<bool> OutpatientPackage()
    {
        await RPMS.SendAsync("YES");
        await RPMS.EnterUntil("Enter Yes or No");
        await RPMS.SendAsync("NO");
        await RPMS.SendAsync("NO");
        return false;
    }
    
    private async Task<bool> UDPackage()
    {
        await RPMS.SendAsync("YES", "^", "^");
        return false;
    }
    
    private async Task<bool> YesAndUphat()
    {
        await RPMS.SendAsync("YES", "^");
        return false;
    }

    private async Task<bool> YesOnly()
    {
        await RPMS.SendAsync("YES");
        return false;
    }

    private async Task GoToNdcChangeMenu()
    {
        await RPMS.GoToMenu("NDC");
        for (int i = 0; i < 3; i++)
        {
            await RPMS.SendAsync(selectedDrug.Id.ToString());
            string prompt = RPMS.CheckPrompt("NDC:", "Select DRUG GENERIC NAME");
            switch (prompt)
            {
                case "NDC:":
                    return;
                case "Select DRUG GENERIC NAME":
                    await Task.Delay(500);
                    await RPMS.GoToMenu("NDC");
                    break;
                default:
                    throw new Exception("Unknown Menu location");
            }
        }
        throw new Exception("Drug not found");
    }
}