@page "/orderdialogs/quickorders"
@using AutoCAC.Models
@inject IDbContextFactory<mainContext> DbFactory
@using AutoCAC.Components.Templates.DataGrids

<PageTitle>Quick Order Search</PageTitle>

<DataGridVanilla TItem="Models.QuickOrderContent" GridModel="GridModel" >
    <RadzenDataGridColumn TItem="AutoCAC.Models.QuickOrderContent" Property="Qoname" Title="Qoname" />
    <RadzenDataGridColumn TItem="AutoCAC.Models.QuickOrderContent" Property="QodisplayName" Title="QodisplayName" />
    <RadzenDataGridColumn TItem="AutoCAC.Models.QuickOrderContent" Property="QodisplayGroup" Title="QodisplayGroup"
                          FilterMode="FilterMode.CheckBoxList" />
    <RadzenDataGridColumn TItem="AutoCAC.Models.QuickOrderContent" Property="EntryType" Title="EntryType" 
        FilterMode="FilterMode.CheckBoxList"/>
    <RadzenDataGridColumn TItem="AutoCAC.Models.QuickOrderContent" Property="Value" Title="Value" />
    <RadzenDataGridColumn TItem="AutoCAC.Models.QuickOrderContent" Property="Id" Title="Id" />
</DataGridVanilla>

@code{
    private DataGridHelper<AutoCAC.Models.QuickOrderContent> GridModel = new()
    {
        SearchColumns=new[]
        {
            nameof(QuickOrderContent.QodisplayName),
            nameof(QuickOrderContent.Qoname),
            nameof(QuickOrderContent.Value)
        }
    };
}