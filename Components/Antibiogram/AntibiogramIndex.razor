@page "/antibiogram"
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AutoCAC.Models.MainContext> DbFactory
@inject UserContextService UserContext
@inject NavigationManager Nav

<RadzenStack Orientation="Orientation.Horizontal">
    <EnumDropdown TEnum="AntibiogramGramStain" @bind-Value="gramStain" Change="@LoadData" />
    <DateRangeSelect @bind-Value="periodSelection" Change="@LoadData" OnlyOptions="@(new[] { PeriodOption.LastYear, PeriodOption.Past365Days, PeriodOption.Custom })"/>
    @if (UserContext?.IsInGroupOrSuperuser("AntibiogramAdmin") == true)
    {
        <RadzenButton Variant="Variant.Text" Text="Admin" Click="@(() => Nav.NavigateToRelative("admin"))" />
    }
</RadzenStack>
<RadzenDataGrid Data="@matrixRows" TItem="AntibiogramMatrixRow" PageSize="10" IsLoading="IsLoading" AllowColumnResize="true"
                AllowPaging="true" PageSizeOptions="@(new[] { 5, 10, 20 })" AllowSorting="true" AllowFiltering="true" 
                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" AllowColumnPicking="true" PickedColumnsChanged="@(x => SelectedColChange(x))">
    <Columns>
        <RadzenDataGridColumn TItem="AntibiogramMatrixRow" Pickable="false"
                              Property="Organism" Width="360px" Filterable="true" Sortable="true"
                              Title="Organism"
                              Frozen="true" FilterMode="FilterMode.Simple" FilterPlaceholder="Search by Organism..."/>
        <RadzenDataGridColumn Width="@($"{compositeCols * 100}px")" Pickable="false">
            <HeaderTemplate>
                <div title="@headingNote">Antibiotic Susceptibility% (Total Tested)<sup>1</sup></div>
            </HeaderTemplate>
            <Columns>
                @foreach (var antibiotic in antibiotics)
                {
                    <RadzenDataGridColumn TItem="AntibiogramMatrixRow"
                                          Title="@antibiotic"
                                          Sortable="false"
                                          Filterable="false" WhiteSpace="WhiteSpace.Wrap">
                        <HeaderTemplate>
                            @{
                                string colName = antibiotic;
                                string title = antibiotic;
                                string superScript = "";
                                switch (antibiotic)
                                {
                                    case "CEFAZOLIN URINE":
                                    case "CEFAZOLIN NONURINE":
                                        title = cefazolinNote;
                                        superScript = "3";
                                        break;
                                    case "GM500":
                                        colName = "GENT SYNERGY";
                                        title = "GENT SYNERGY (GM500)";
                                        break;
                                    case "ST1000":
                                        colName = "STREPT SYNERGY";
                                        title = "STREPT SYNERGY (ST1000)";
										break;
                                }
                            }
                            <div title="@title" style="writing-mode: vertical-rl; transform: rotate(180deg);">
								<span>@colName</span>
								<sup>@superScript</sup>
							</div>
                        </HeaderTemplate>
                        <Template Context="row">
                            @if (row.Values.TryGetValue(antibiotic, out var pct))
                            {
                                var ct = row.Counts.GetValueOrDefault(antibiotic);
                                bool isUnder = ct < isolateWarningPoint;
                                if(isUnder)
                                {
                                    <div class="rz-color-danger-darker" title="@clsiNote">
                                        <span>@pct.ToString("0")%</span>
                                        <span> (@ct)<sup>2</sup></span>
                                    </div>
                                }
                                else
                                {
                                    <div class="rz-color-success-darker">
                                        <span>@pct.ToString("0")%</span>
                                        <span> (@ct)</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                }
            </Columns>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>
<RadzenFooter>
    <ol>
        <li>@headingNote</li>
        <li>@clsiNote</li>
        <li>@cefazolinNote</li>
    </ol>
</RadzenFooter>
@code {
    PeriodSelection periodSelection = new PeriodSelection(PeriodOption.Past365Days);
    int compositeCols = 1;
    int isolateWarningPoint = 30;
	int isolateFilterPoint = 15;
    string clsiNote;
    string headingNote = @"Percentage (%) represents the proportion of isolates classified as susceptible (susceptible isolates ÷ total isolates tested). 
The value in parentheses indicates the total number of isolates evaluated.";
    string cefazolinNote = @"Cefazolin has distinct susceptibility breakpoints for urinary vs non-urinary infections. 
For systemic infections (e.g., bacteremia, pneumonia), the susceptible breakpoint is ≤2 µg/mL.
For uncomplicated cystitis, a higher urine-specific breakpoint (≤16 µg/mL) is used because cefazolin achieves high urinary concentrations. 
Results interpreted as susceptible using urine breakpoints should only be applied to uncomplicated cystitis and not to pyelonephritis or invasive infections. 
Cefazolin may be used as a surrogate marker for susceptibility to oral cephalosporins for uncomplicated UTI.";
    public enum AntibiogramGramStain
	{
		BothGramNegativeAndPositive,
		GramPositive,
		GramNegative
	}
	AntibiogramGramStain gramStain = AntibiogramGramStain.GramPositive;
	IEnumerable<AntibiogramDto> data;
	List<string> antibiotics = [];
	IEnumerable<AntibiogramMatrixRow> matrixRows;
	bool IsLoading = true;
	protected override void OnInitialized()
	{
        clsiNote = @$"Data from fewer than {isolateWarningPoint} isolates fall below the CLSI M100 threshold and should be interpreted cautiously with clinical judgment.";
	}
	protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
        }
    }

    private async Task SelectedColChange(DataGridPickedColumnsChangedEventArgs<AntibiogramMatrixRow> cols)
    {
        compositeCols = cols.Columns.Count();
    }

    private async Task LoadData()
    {
        IsLoading = true;

        try
        {
            var start = periodSelection.CurrentStart.StartOfDay;
            var end = periodSelection.CurrentEnd.StartOfNextDay;

            await using var db = await DbFactory.CreateDbContextAsync();

            var baseQuery = db.Microbios
                .Where(a => a.Result == "S" || a.Result == "R" || a.Result == "I")
                .Where(x => x.CollectionDateTime >= start && x.CollectionDateTime < end)
                .Where(x => x.Antibiotic != null && x.Organism != null);

            baseQuery = gramStain switch
            {
                AntibiogramGramStain.GramPositive => baseQuery.Where(x => x.GramStain == "GRAM POSITIVE"),
                AntibiogramGramStain.GramNegative => baseQuery.Where(x => x.GramStain == "GRAM NEGATIVE"),
                _ => baseQuery
            };

            var shapedQuery = baseQuery.Select(x => new
            {
                x.Id,
                x.PatientId,

                // Keep this as the original organism for deduplication.
                x.Organism,

                x.Result,
                x.CollectionDateTime,

                Antibiotic = x.Antibiotic == "CEFAZOLIN"
                    ? "CEFAZOLIN" + (EF.Functions.Like(x.Culture, "%urine%") ? " URINE" : " NONURINE")
                    : x.Antibiotic
            });

            var firstIdsPerCulture = shapedQuery
                .GroupBy(x => new
                {
                    x.PatientId,
                    x.Antibiotic,
                    x.Organism,
                    x.CollectionDateTime
                })
                .Select(g => g.Min(x => x.Id));

            var deduped = shapedQuery
                .Where(x => firstIdsPerCulture.Contains(x.Id));

            var mappedQuery =
                from x in deduped
                join mapping in db.AntibiogramOrganismMappings
                    on x.Organism equals mapping.Organism into mappingJoin
                from mapping in mappingJoin.DefaultIfEmpty()
                select new
                {
                    x.Antibiotic,

                    // Use mapped group name when present; otherwise use original organism.
                    Organism = mapping == null
                        ? x.Organism
                        : mapping.AntibiogramOrganismGroupName,

                    x.Result
                };

            data = await mappedQuery
                .GroupBy(x => new
                {
                    x.Antibiotic,
                    x.Organism
                })
                .Select(g => new AntibiogramDto
                {
                    Antibiotic = g.Key.Antibiotic,
                    Organism = g.Key.Organism,
                    Susceptible = g.Sum(x => x.Result == "S" ? 1 : 0),
                    TotalCount = g.Count()
                })
                .ToListAsync();

            var includedOrganisms = data
                .GroupBy(x => x.Organism)
                .Where(g => g.Max(x => x.TotalCount) >= isolateFilterPoint)
                .Select(g => g.Key)
                .ToHashSet();

            data = data
                .Where(x => includedOrganisms.Contains(x.Organism))
                .ToList();

            antibiotics = data
                .Select(x => x.Antibiotic)
                .Distinct()
                .OrderBy(x => x)
                .ToList();

            matrixRows = data
                .GroupBy(x => x.Organism)
                .Select(g => new AntibiogramMatrixRow
                {
                    Organism = g.Key,
                    Values = g.ToDictionary(x => x.Antibiotic, x => x.PctS),
                    Counts = g.ToDictionary(x => x.Antibiotic, x => x.TotalCount)
                })
                .OrderBy(x => x.Organism)
                .ToList();

            compositeCols = antibiotics.Count;
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    public class AntibiogramDto
    {
        public string Organism { get; set; }
        public string Antibiotic { get; set; }
        public int Susceptible { get; set; }
        public int TotalCount { get; set; }
        public decimal PctS => TotalCount == 0 ? 0 : (decimal)Susceptible / TotalCount * 100;
    }

    public class AntibiogramMatrixRow
    {
        public string Organism { get; set; }
        public Dictionary<string, decimal> Values { get; set; } = new();
        public Dictionary<string, int> Counts { get; set; } = new();
    }
}