@page "/admin/alert/{Id:int}"
@using AutoCAC.Components.Templates.Buttons
@using AutoCAC.Models
@inject IDbContextFactory<MainContext> DbFactory
@inject NavigationManager Nav
@using AutoCAC.Common.Alerts
@inject DialogService DialogService
<BackLink />
<LoadingContent LoadState="@((data == null) ? LoadingState.Loading : LoadingState.Loaded)">
	<h3>@data?.DisplayName</h3>
	<p>@data?.Description</p>
	<RadzenButton Text="Edit Attributes" Click="EditAttributes" />

    <hr />

    <h4>Rule Nodes</h4>

    @if (data != null && !RootNodes.Any())
    {
        <p>No rule nodes yet.</p>
        <RadzenButton Text="Add Root Group" Click="@(() => AddRootNode())" class="rz-my-2" Icon="add" ButtonStyle="ButtonStyle.Success" />
    }
    else
    {
        <RadzenDataList Data="RootNodes">
            <Template Context="root">
                <AlertDefRuleNodeTree Node="root" AllNodes="data.AlertDefRuleNodes.ToList()" AfterAdd="@LoadData" OnEditNode="@EditRuleNode" />
            </Template>
        </RadzenDataList>
    }
</LoadingContent>

@code {
    [Parameter] public int Id { get; set; }

    private AlertDef data { get; set; }

    private List<AlertDefRuleNode> RootNodes =>
        data?.AlertDefRuleNodes
            .Where(x => x.ParentId == null)
            .OrderBy(x => x.Id)
            .ToList()
        ?? new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();

        data = await db.AlertDefs
            .Include(x => x.AlertDefRuleNodes)
            .SingleOrDefaultAsync(x => x.Id == Id);
		StateHasChanged();
    }

    private async Task EditAttributes()
    {
        var result = await DialogService.OpenDefaultAsync<AlertDefDialog, AlertDef>(
            "Edit Alert Definition",
            new Dictionary<string, object>() { { "Data", data } });

        await LoadData();
    }
    private async Task EditRuleNode(AlertDefRuleNode node)
    {
        var result = await DialogService.OpenDefaultAsync<AlertNodeDialog, AlertDefRuleNode>(
            "Edit Rule Node",
            new Dictionary<string, object>
            {
                { "Data", node }
            });

        if (result != null)
        {
            await LoadData();
        }
    }

    private async Task AddRootNode()
    {
        var newNode = new AlertDefRuleNode
        {
            AlertDefId = data.Id,
            NodeType = AlertNodeTypeEnum.Group.ToString(),
            IsActive = true,
            ChildOperator = "All"
        };
		await DbFactory.AddItemAsync(newNode);
        await LoadData();
    }
}